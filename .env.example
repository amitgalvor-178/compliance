# Server
PORT=3000

# Azure OpenAI — same deployment as galvor-tech/workflows
AZURE_OPEN_AI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPEN_AI_KEY=your-azure-openai-key

# Standard OpenAI key — used only for Moderation API (no Azure equivalent)
OPENAI_MODERATION_API_KEY=sk-...

# Meta Graph API — needs Instagram Business account with Business Discovery enabled
META_ACCESS_TOKEN=your-long-lived-page-token
META_IG_USER_ID=your-instagram-business-account-id

# Langfuse tracing (optional — remove validation in config/langfuse.ts for local dev)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_SAMPLE_RATE=1.0

# Rate limiting for LLM calls (defaults match workflows repo)
ANALYSIS_MAX_CONCURRENT=5
ANALYSIS_MIN_TIME_MS=10
ANALYSIS_MAX_RETRIES=3

# Optional: comma-separated competitor brand names to flag
COMPETITOR_BRANDS=CompetitorA,CompetitorB
